[DEFAULT]
# Network Interface Settings
monitor_mode = true
auto_select_interface = false
preferred_interface = wlan0

# Scanning Settings
scan_timeout = 30
max_networks_display = 50
show_hidden_networks = false
scan_interval = 5

# Attack Settings
default_attack_duration = 300
max_attack_threads = 5
packet_rate = 1000
deauth_reason_code = 7
use_random_mac = true

# Logging Settings
log_level = INFO
log_file = logs/wifi_jammer.log
max_log_size = 10485760  # 10MB
backup_count = 5

# Safety Settings
require_confirmation = true
enable_killswitch = true
killswitch_key = ctrl+c
max_targets = 10

# Interface Settings
use_colors = true
refresh_rate = 2
terminal_type = auto